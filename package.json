{
    "name": "semantic-linker",
    "version": "0.0.3",
    "description": "Semantic Linker for Obsidian (https://obsidian.md)",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "watch:css": "pnpm tailwindcss -i ./src/input.css -o ./styles.css --watch",
        "watch": "node esbuild.config.mjs watch",
        "build:css": "pnpm tailwindcss -i ./src/input.css -o ./styles.css --minify",
        "build": "pnpm build:css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint:md": "eslint .",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "all": "pnpm format && pnpm lint && pnpm lint:md && pnpm build"
    },
    "keywords": [],
    "devDependencies": {
        "@biomejs/biome": "2.3.13",
        "@tailwindcss/cli": "^4.2.1",
        "@types/node": "^25.3.3",
        "esbuild": "0.27.2",
        "eslint": "^9.39.3",
        "eslint-plugin-obsidianmd": "^0.1.9",
        "globals": "^17.4.0",
        "ignore": "^7.0.5",
        "jiti": "2.6.1",
        "js-tiktoken": "^1.0.21",
        "ollama": "^0.6.3",
        "tailwindcss": "^4.2.1",
        "tslib": "2.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "8.54.0"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}
